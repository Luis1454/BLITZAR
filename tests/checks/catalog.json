{
  "check_registry": {
    "checks": {
      "ini": "python_tools.policies.ini_check.IniCheck",
      "mirror": "python_tools.policies.mirror_check.MirrorCheck",
      "no_legacy": "python_tools.policies.no_legacy_check.NoLegacyCheck",
      "launcher": "python_tools.policies.launcher_check.LauncherContractCheck",
      "quality": "python_tools.policies.quality_baseline.QualityBaselineCheck",
      "cpp_api_docs": "python_tools.policies.cpp_api_documentation_policy.CppApiDocumentationCheck",
      "test_catalog": "python_tools.policies.test_catalog.TestCatalogCheck",
      "pr_policy": "python_tools.policies.pr_policy.PrPolicySelfTestCheck",
      "repo": "python_tools.policies.repo_policy.RepoPolicyCheck",
      "python_quality": "python_tools.ci.python_quality_gate.PythonQualityGateCheck"
    },
    "sequences": {
      "all": ["ini", "mirror", "no_legacy", "quality", "test_catalog", "pr_policy", "repo"],
      "quality": ["quality", "cpp_api_docs", "test_catalog", "pr_policy"]
    }
  },
  "commands": {
    "clang_tidy": {
      "description": "Run clang-tidy over selected compile database entries.",
      "check": "python_tools.ci.clang_tidy.ClangTidyCheck",
      "arguments": [
        {"flags": ["--build-dir"], "dest": "build_dir", "required": true, "help": "Build directory containing compile_commands.json"},
        {"flags": ["--root"], "default": ".", "help": "Repository root"},
        {"flags": ["--clang-tidy"], "dest": "clang_tidy", "default": "clang-tidy", "help": "clang-tidy executable"},
        {"flags": ["--checks"], "default": "-*,clang-analyzer-*,bugprone-unused-return-value", "help": "clang-tidy checks expression"},
        {"flags": ["--jobs"], "default": 0, "type": "int", "help": "Parallel clang-tidy jobs (0 = auto)"},
        {"flags": ["--log-dir"], "dest": "log_dir", "default": null, "help": "Directory to store clang-tidy logs"},
        {"flags": ["--diff-base"], "default": "", "help": "Git base ref for diff-only clang-tidy"},
        {"flags": ["--diff-target"], "default": "", "help": "Git target ref for diff-only clang-tidy"},
        {"flags": ["--header-filter"], "dest": "header_filter", "default": "([/\\\\]|^)(apps|engine|runtime|modules|tests)([/\\\\])", "help": "clang-tidy header filter regex"},
        {"flags": ["--file-timeout-sec"], "dest": "file_timeout_sec", "default": 0, "type": "int", "help": "Per-file timeout for clang-tidy (0 disables timeout; strict evidence mode)"},
        {"flags": ["--timeout-fallback-checks"], "dest": "timeout_fallback_checks", "default": "", "help": "Checks used when analyzer times out for a file (empty disables fallback; strict evidence mode)"},
        {"flags": ["--path"], "dest": "paths", "action": "append", "default": [], "help": "Restrict analysis to this repo-relative path (repeatable)"}
      ],
      "context": {
        "root": {"source": "arg", "name": "root", "path": "resolve"},
        "build_dir": {"source": "arg", "name": "build_dir", "path": "resolve"},
        "clang_tidy_binary": {"source": "arg", "name": "clang_tidy"},
        "clang_tidy_checks": {"source": "arg", "name": "checks"},
        "clang_tidy_jobs": {"source": "arg", "name": "jobs"},
        "clang_tidy_log_dir": {"source": "arg", "name": "log_dir", "path": "resolve"},
        "clang_tidy_diff_base": {"source": "arg", "name": "diff_base"},
        "clang_tidy_diff_target": {"source": "arg", "name": "diff_target"},
        "clang_tidy_header_filter": {"source": "arg", "name": "header_filter"},
        "clang_tidy_file_timeout_sec": {"source": "arg", "name": "file_timeout_sec"},
        "clang_tidy_timeout_fallback_checks": {"source": "arg", "name": "timeout_fallback_checks"},
        "paths": {"source": "arg", "name": "paths", "tuple": true}
      }
    },
    "pr_policy": {
      "description": "Validate AGENTS PR policy (branch/title/body coherence).",
      "check": "python_tools.policies.pr_policy.PrPolicyCheck",
      "arguments": [
        {"flags": ["--event-name"], "dest": "event_name", "default": "", "default_env": "GITHUB_EVENT_NAME", "help": "GitHub event name"},
        {"flags": ["--event-path"], "dest": "event_path", "default": "", "default_env": "GITHUB_EVENT_PATH", "help": "Path to GitHub event payload JSON"},
        {"flags": ["--branch"], "default": "", "help": "Override PR branch name (issue/<N>-<slug>)"},
        {"flags": ["--title"], "default": "", "help": "Override PR title"},
        {"flags": ["--body"], "default": "", "help": "Override PR body"}
      ],
      "context": {
        "root": {"source": "repo_root"},
        "event_name": {"source": "arg", "name": "event_name"},
        "event_path": {"source": "arg", "name": "event_path"},
        "branch": {"source": "arg", "name": "branch"},
        "title": {"source": "arg", "name": "title"},
        "body": {"source": "arg", "name": "body"}
      }
    },
    "main_delivery_gate": {
      "description": "Validate that pushes to main originate from merged issue pull requests.",
      "check": "python_tools.policies.main_delivery_policy.MainDeliveryGateCheck",
      "arguments": [
        {"flags": ["--event-name"], "dest": "event_name", "default": "", "default_env": "GITHUB_EVENT_NAME", "help": "GitHub event name"},
        {"flags": ["--event-path"], "dest": "event_path", "default": "", "default_env": "GITHUB_EVENT_PATH", "help": "Path to GitHub event payload JSON"},
        {"flags": ["--repo"], "default": "", "default_env": "GITHUB_REPOSITORY", "help": "owner/repo"},
        {"flags": ["--sha"], "default": "", "default_env": "GITHUB_SHA", "help": "Commit SHA to validate"}
      ],
      "context": {
        "root": {"source": "repo_root"},
        "event_name": {"source": "arg", "name": "event_name"},
        "event_path": {"source": "arg", "name": "event_path"},
        "options": {
          "source": "mapping",
          "items": {
            "repo": {"source": "arg", "name": "repo"},
            "token": {"source": "env", "name": "GITHUB_TOKEN", "default": ""},
            "sha": {"source": "arg", "name": "sha"}
          }
        }
      }
    },
    "traceability_gate": {
      "description": "Validate requirement traceability for critical pull requests.",
      "check": "python_tools.policies.traceability_gate.TraceabilityGateCheck",
      "arguments": [
        {"flags": ["--event-name"], "dest": "event_name", "default": "", "default_env": "GITHUB_EVENT_NAME", "help": "GitHub event name"},
        {"flags": ["--event-path"], "dest": "event_path", "default": "", "default_env": "GITHUB_EVENT_PATH", "help": "Path to GitHub event payload JSON"},
        {"flags": ["--repo"], "default": "", "default_env": "GITHUB_REPOSITORY", "help": "GitHub owner/repo slug"}
      ],
      "context": {
        "root": {"source": "repo_root"},
        "event_name": {"source": "arg", "name": "event_name"},
        "event_path": {"source": "arg", "name": "event_path"},
        "options": {
          "source": "mapping",
          "items": {
            "repo": {"source": "arg", "name": "repo"},
            "token": {"source": "env", "name": "GITHUB_TOKEN", "default": ""}
          }
        }
      }
    },
    "ivv_gate": {
      "description": "Validate IV&V independence gate for PRs.",
      "check": "python_tools.policies.ivv_gate.IvvGateCheck",
      "arguments": [
        {"flags": ["--event-name"], "dest": "event_name", "default": "", "default_env": "GITHUB_EVENT_NAME", "help": "GitHub event name"},
        {"flags": ["--event-path"], "dest": "event_path", "default": "", "default_env": "GITHUB_EVENT_PATH", "help": "Path to GitHub event payload JSON"},
        {"flags": ["--repo"], "default": "", "default_env": "GITHUB_REPOSITORY", "help": "GitHub repository owner/name"},
        {"flags": ["--token"], "default": "", "default_env": "GITHUB_TOKEN", "help": "GitHub token used to query PR metadata"}
      ],
      "context": {
        "root": {"source": "repo_root"},
        "event_name": {"source": "arg", "name": "event_name"},
        "event_path": {"source": "arg", "name": "event_path"},
        "options": {
          "source": "mapping",
          "items": {
            "repo": {"source": "arg", "name": "repo"},
            "token": {"source": "arg", "name": "token"}
          }
        }
      }
    }
  }
}
